# Akonado - AI Visual Novel Asset Generator
# Copy this file to .env and fill in your API keys.
# .env is git-ignored and will NOT be committed.

# ============================================================
# LLM Provider (OpenAI-compatible API)
# Used for: one-sentence -> script + characters generation
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro

# ============================================================
# MiMo TTS (Xiaomi Cloud - OpenAI-compatible)
# Used for: character voice synthesis
# ============================================================
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts

# ============================================================
# Qwen3 TTS (Local inference -- GPU required)
# Used for: character voice synthesis (alternative engine)
# Requires: pip install -e /path/to/qwen3-tts
# ============================================================
QWEN_TTS_MODEL_PATH=
QWEN_TTS_DEVICE=cuda:0
QWEN_TTS_DTYPE=bfloat16

# ============================================================
# ComfyUI (Local)
# Used for: character art, backgrounds, BGM, SFX, UI images
# ============================================================
COMFYUI_URL=http://127.0.0.1:8188

# ============================================================
# Web GUI
# ============================================================
WEB_HOST=127.0.0.1
WEB_PORT=5000
WEB_DEBUG=false
